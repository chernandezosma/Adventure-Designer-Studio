# True let the messages be printed out
DEBUG=true

# LANGUAGES actives for the application
LANGUAGES=es_ES,de_DE,en_US,fr_FR,it_IT,pt_PT,ru_RU

# Font size for base calculations
FONT_SIZE_BASE=14.0f

# Font used in the GUI UI
LIGHT_FONT=public/fonts/Roboto/static/Roboto-Light.ttf
MEDIUM_FONT=public/fonts/Roboto/static/Roboto-Medium.ttf
REGULAR_FONT=public/fonts/Roboto/static/Roboto-Regular.ttf

# Tooltip delay in seconds before showing tooltip on hover
TOOLTIP_DELAY=0.5

# Manual DPI scale override for X11 setups where SDL3 cannot detect HiDPI automatically.
# Set to your monitor's scale factor (e.g. 2.0 for 4K at 200%, 1.5 for 150%).
# Leave commented-out on Wayland / macOS / Windows where SDL3 detects the scale automatically.
DISPLAY_SCALE=1.5

